# Copy to .env: cp .env.example .env
# Never commit .env (real keys). Example values below are placeholders only.

# --- Core (matches a minimal local setup) ---

# Gemini — labels, embeddings, optional image gen. https://aistudio.google.com/apikey
GEMINI_API_KEY=

# HydraDB — vector / wardrobe backend when used by the app
HYDRADB_API_KEY=

# JWT — sign auth tokens (/api/auth/*, face enroll, /api/segment/me). Use a long random string in production.
JWT_SECRET=styleme-hackathon-secret-change-me

# Allowed browser origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Optional HydraDB tenant (default in code: styleme)
# HYDRADB_TENANT_ID=styleme

# --- SAM 3 (segmentation) ---
# Weights are not auto-downloaded. Request access: https://huggingface.co/facebook/sam3
# SAM3_WEIGHTS=/path/to/sam3.pt
# SAM3_IMG_SIZE=1024
# SAM3_MIN_CONFIDENCE=0.60
# SEGMENTS_OUTPUT_DIR=/path/to/exports
# SAVE_SEGMENTS=0

# Gemini — model overrides (optional)
# GEMINI_MODEL=gemini-3.1-flash-lite-preview
# GEMINI_CONTEXT_MAX_EDGE=1024
# GEMINI_CROP_PAD_FRAC=0.06

# Virtual try-on (optional)
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
# TRYON_MAX_SEGMENTS=14
# TRYON_USER_MAX_EDGE=1536

# API server (main.py)
# HOST=0.0.0.0
# PORT=8000

# --- Face enrollment + face-grounded segmentation (/api/identity/enroll, /api/segment/me) ---
# INSIGHTFACE_ROOT=/path/to/.insightface
# INSIGHTFACE_MODEL=buffalo_l
# INSIGHTFACE_CTX_ID=-1
# IDENTITY_EMBED_DIR=/path/to/identity
# FACE_MATCH_MIN=0.40
# MASK_OVERLAP_MIN=0.25

# Upload / image limits (optional; defaults in config.py)
# MAX_UPLOAD_IMAGES=20
# IMAGE_MAX_SIZE_PX=1024
# EMBEDDING_DIMENSIONS=768
