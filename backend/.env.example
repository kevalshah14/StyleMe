# Copy to .env if needed: cp .env.example .env

# SAM 3 weights (not auto-downloaded). Request access and download from:
# https://huggingface.co/facebook/sam3
# Then set the path to your `sam3.pt` file:
# SAM3_WEIGHTS=/path/to/sam3.pt

# Square inference size for SAM 3 (default 1024)
# SAM3_IMG_SIZE=1024

# Minimum detection score to keep in API output (default 0.60)
# SAM3_MIN_CONFIDENCE=0.60

# Where to save RGBA cutout PNGs per run (default: backend/segments)
# SEGMENTS_OUTPUT_DIR=/path/to/exports
# SAVE_SEGMENTS=0

# Gemini — clothing labels per segment (POST /api/segment with annotate=true)
# Get a key: https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3.1-flash-lite-preview
# GEMINI_CONTEXT_MAX_EDGE=1024
# GEMINI_CROP_PAD_FRAC=0.06

# Virtual try-on image generation (Nano Banana 2)
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
# TRYON_MAX_SEGMENTS=14
# TRYON_USER_MAX_EDGE=1536

# API server (main.py)
# HOST=0.0.0.0
# PORT=8000
# CORS_ORIGINS=http://localhost:3000

# Face enrollment + face-grounded segmentation (POST /api/identity/enroll, POST /api/segment/me)
# Models download under INSIGHTFACE_ROOT on first run (~buffalo_l).
# INSIGHTFACE_ROOT=/path/to/.insightface
# INSIGHTFACE_MODEL=buffalo_l
# INSIGHTFACE_CTX_ID=-1
# Embeddings: one NPZ per user under IDENTITY_EMBED_DIR (default backend/data/identity/)
# IDENTITY_EMBED_DIR=/path/to/identity
# Cosine similarity threshold for matching a face to the enrolled embedding (typical ~0.35–0.45)
# FACE_MATCH_MIN=0.40
# Min fraction of a clothing mask that must overlap the person region (typical ~0.2–0.3)
# MASK_OVERLAP_MIN=0.25
